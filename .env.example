# Copy to .env.local and fill in your Supabase project's values.
# Find these in the Supabase dashboard → Project Settings → API.
# Use the publishable (anon) key — it's meant for the browser; row access is
# governed by RLS policies (only authenticated users can read/write).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Your login (an account created in Supabase Auth). Used ONLY by scripts/db.mjs
# to sign in for writes (seed / photos / upsert) — never bundled into the app.
SUPABASE_EMAIL=you@example.com
SUPABASE_PASSWORD=your-password
